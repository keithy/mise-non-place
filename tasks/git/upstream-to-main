#!/bin/bash
#MISE description="Sync main with upstream (with confirmation)"
#MISE raw=true
set -euo pipefail

cd "$MISE_PROJECT_ROOT"

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Detect --dry-run mode
if [ "${1:-}" = "--dry-run" ]; then
    DRY_RUN=true
else
    DRY_RUN=false
fi

# Save current branch (to potentially restore if we were on it)
user_branch=$(git branch --show-current 2>/dev/null || echo "")

# Fix dubious ownership (need both dir and .git)
git config --global --add safe.directory "$MISE_PROJECT_ROOT" 2>/dev/null || true
git config --global --add safe.directory "$MISE_PROJECT_ROOT/.git" 2>/dev/null || true

# Run in temp directory to leave working tree untouched
temp_dir=$(mktemp -d)

cleanup() {
    rm -rf "$temp_dir"
}
trap cleanup EXIT

# Create a regular clone (preserves all remotes)
echo "Creating temp repo for sync..."
git -c safe.directory="$MISE_PROJECT_ROOT" clone "$MISE_PROJECT_ROOT" "$temp_dir"
git -C "$temp_dir" config safe.directory "$temp_dir"

# Copy remotes from original config
cp "$MISE_PROJECT_ROOT/.git/config" "$temp_dir/.git/config"

# Ensure we're on main branch
git -C "$temp_dir" checkout main

cd "$temp_dir"

# Check upstream remote exists
if ! git remote get-url upstream &>/dev/null; then
    echo "upstream remote not configured. Run: upstream-init.sh"
    exit 1
fi

echo "========================================"
echo "  upstream-to-main: Sync main with upstream"
echo "========================================"
echo ""

git fetch upstream

local_head=$(git rev-parse HEAD)
remote_head=$(git rev-parse upstream/main)
origin_head=$(git rev-parse origin/main 2>/dev/null || echo "(not set)")

echo "Current state:"
echo "  Local main:   $(git rev-parse --short "$local_head")"
echo "  Upstream:     $(git rev-parse --short "$remote_head")"
echo "  Origin/main:  $(git rev-parse --short "$origin_head" 2>/dev/null || echo "(not tracking)")"
echo ""

# Check if already up to date
if [[ "$local_head" == "$remote_head" ]]; then
    echo "✓ Already up to date with upstream/main"
    exit 0
fi

# Count commits ahead/behind
commits_ahead=$(git rev-list --count upstream/main..HEAD 2>/dev/null || echo "0")
commits_behind=$(git rev-list --count HEAD..upstream/main 2>/dev/null || echo "0")

echo "Difference:"
echo "  Upstream is $commits_behind commits ahead"
echo "  Local is $commits_ahead commits ahead"
echo ""

# Check for divergence
diverged=false
if ! git merge-base --is-ancestor "$remote_head" HEAD 2>/dev/null; then
    diverged=true
    echo "⚠️  WARNING: Local main has DIVERGED from upstream!"
    echo "    (Local contains commits not in upstream)"
fi

echo "========================================"
echo ""
echo "This will:"
echo "  1. Reset local main to upstream/main (discards local commits)"
if [ "$origin_head" != "(not set)" ]; then
    echo "  2. Force-push to origin/main (your fork on GitHub)"
fi
echo ""
echo "========================================"
echo ""

if [ "$DRY_RUN" = true ]; then
    echo "[DRY RUN] No changes made. Run without --dry-run to proceed."
    exit 0
fi

# Confirmation prompt
echo -n "Proceed? (y/n) "
read -r response
if [[ "$response" != "y" && "$response" != "Y" ]]; then
    echo "Aborted."
    exit 0
fi

# Fast-forward reset - clean sync, no merge commits
echo ""
echo "Resetting main to upstream/main..."
git reset --hard upstream/main
echo "✓ Done"

# Also update origin/main to match
if git remote get-url origin &>/dev/null; then
    echo ""
    echo "Pushing to origin/main..."
    git push origin main --force-with-lease
    echo "✓ Pushed to origin/main"
fi

echo ""
echo "========================================"
echo "✓ Sync complete"
echo "========================================"
