#!/usr/bin/env bash
#MISE description="Add a worktree to a picked project"
#MISE raw="true"

# worktree/add - Add a worktree to a project
# Usage:
#   mise run worktree:add [<worktree_name> [<template>]]

set -euo pipefail

MNP_ROOT="${MISE_PROJECT_ROOT}"
MNP_NAME="${MNP_ROOT##*/}"

# Get target from pick
TARGET_DIR="$(git config --local --get "${MNP_NAME}.picked" 2>/dev/null || true)"
if [ -z "$TARGET_DIR" ]; then
    echo "Error: No project selected. Run 'mise run pick /path/to/project' first." >&2
    exit 1
fi

# Parse args: [<worktree_name> [<template>]]
WORKTREE_NAME="${1:-}"
TEMPLATE="${2:-}"

# Get defaults from config
DEFAULT_TEMPLATE="${MISE_TEMPLATE_DEFAULT:-template/empty}"

# If no args, prompt interactively
if [ -z "$WORKTREE_NAME" ]; then
    read -p "Worktree name (default: mise): " WORKTREE_NAME
    WORKTREE_NAME="${WORKTREE_NAME:-mise}"
    read -p "Template branch (default: $DEFAULT_TEMPLATE): " TEMPLATE
    TEMPLATE="${TEMPLATE:-$DEFAULT_TEMPLATE}"
elif [ -z "$TEMPLATE" ]; then
    TEMPLATE="$DEFAULT_TEMPLATE"
fi

TARGET_DIR="$(realpath "$TARGET_DIR")"

if [ ! -d "$TARGET_DIR" ]; then
    echo "Error: Directory '$TARGET_DIR' does not exist." >&2
    exit 1
fi

if [ ! -d "$TARGET_DIR/.git" ]; then
    echo "Error: '$TARGET_DIR' is not a git repository." >&2
    exit 1
fi

TARGET_MNP="$TARGET_DIR/.$MNP_NAME"
TARGET_WT="$TARGET_DIR/$WORKTREE_NAME"

if [ -d "$TARGET_WT" ]; then
    echo "Error: Worktree '$WORKTREE_NAME' already exists in $TARGET_DIR" >&2
    exit 1
fi

echo "Injecting into: $TARGET_DIR"
echo "Template: $TEMPLATE, Worktree: $WORKTREE_NAME"
echo ""

# Clone if not already present
if [ ! -d "$TARGET_MNP" ]; then
    echo "Cloning .$MNP_NAME into $TARGET_DIR..."
    MNP_ORIGIN_URL="$(git -C "$MNP_ROOT" remote get-url origin)"
    git clone "$MNP_ORIGIN_URL" "$TARGET_MNP"
    
    # Add upstream if it exists in the source
    git -C "$MNP_ROOT" remote get-url upstream &>/dev/null && \
        git -C "$TARGET_MNP" remote add upstream "$(git -C "$MNP_ROOT" remote get-url upstream)"
else
    echo "Using existing .$MNP_NAME in $TARGET_DIR"
fi

# Update pick to point to the new project
git config --local "${MNP_NAME}.picked" "$TARGET_DIR"

echo "Updated pick to: $TARGET_DIR"

branch_name="$(basename "$TARGET_DIR")/$WORKTREE_NAME"
branch_name="${branch_name//\/\./\/%2E}"
branch_name="${branch_name// /%20}"

echo "Creating worktree '$WORKTREE_NAME'..."
# Check if template branch exists in any remote, fetch if not
TEMPLATE_EXISTS=false
for remote in origin upstream; do
    if git -C "$TARGET_MNP" show-ref --verify --quiet "refs/remotes/$remote/$TEMPLATE"; then
        TEMPLATE_EXISTS=true
        break
    fi
done

if ! $TEMPLATE_EXISTS; then
    echo "Fetching template branch $TEMPLATE..."
    for remote in origin upstream; do
        if git -C "$TARGET_MNP" fetch "$remote" "+refs/heads/$TEMPLATE:refs/remotes/$remote/$TEMPLATE" 2>&1; then
            if git -C "$TARGET_MNP" show-ref --verify --quiet "refs/remotes/$remote/$TEMPLATE"; then
                TEMPLATE_EXISTS=true
                break
            fi
        fi
    done
fi

if ! $TEMPLATE_EXISTS; then
    echo "Error: Template branch '$TEMPLATE' not found." >&2
    exit 1
fi

if git -C "$TARGET_MNP" show-ref --verify --quiet "refs/remotes/origin/$branch_name"; then
    echo "Branch $branch_name exists on origin. Using it."
    git -C "$TARGET_MNP" worktree add "../$WORKTREE_NAME" "$branch_name"
else
    echo "Creating new branch $branch_name from $TEMPLATE..."
    # Find which remote has the template
    TEMPLATE_REF=""
    for remote in origin upstream; do
        if git -C "$TARGET_MNP" show-ref --verify --quiet "refs/remotes/$remote/$TEMPLATE"; then
            TEMPLATE_REF="$remote/$TEMPLATE"
            break
        fi
    done
    if [ -z "$TEMPLATE_REF" ]; then
        echo "Error: Template $TEMPLATE not found" >&2
        exit 1
    fi
    # Create branch from remote ref
    git -C "$TARGET_MNP" branch "$branch_name" "$TEMPLATE_REF"
    # Make branch track itself (set remote to local)
    git -C "$TARGET_MNP" config "branch.$branch_name.remote" .
    git -C "$TARGET_MNP" config "branch.$branch_name.merge" "refs/heads/$branch_name"
    # Then add worktree with the branch
    git -C "$TARGET_MNP" worktree add "../$WORKTREE_NAME" "$branch_name"
fi

echo "Trusting mise configuration..."
(cd "$TARGET_DIR/$WORKTREE_NAME" && mise trust)
(cd "$TARGET_MNP" && mise trust)

echo "Adding to .git/info/exclude..."
mkdir -p "$TARGET_DIR/.git/info"
exclude_file="$TARGET_DIR/.git/info/exclude"

for f in ".$MNP_NAME" "$WORKTREE_NAME"; do
    grep -qFx "$f/" "$exclude_file" 2>/dev/null || echo "$f/" >> "$exclude_file"
done

echo "Done! cd into $TARGET_DIR/$WORKTREE_NAME"
