#!/bin/bash
#MISE description="Manage PRs to pull (+num to add, -num to remove, or list)"
set -e
cd "$MISE_PROJECT_ROOT"

TASK_NAME="${MISE_TASK_NAME##*:}"
MD_FILE="$MISE_PROJECT_ROOT/${DEV_DATA_DIR}/${TASK_NAME}.md"
JSON_FILE="$MISE_PROJECT_ROOT/${DEV_DATA_DIR}/${TASK_NAME}.json"

# Ensure both files exist
init_files() {
    if [[ ! -f "$MD_FILE" ]]; then
        case "$TASK_NAME" in
            like) title="Interested PRs" ;;
            *) title="PRs to Pull" ;;
        esac
        cat > "$MD_FILE" << EOF
# $title

| PR | Description | Status |
|----|-------------|--------|

EOF
    fi
    if [[ ! -f "$JSON_FILE" ]]; then
        echo "[]" > "$JSON_FILE"
    fi
}

# Sync MD from JSON (master)
json2md() {
    local tmp_md
    tmp_md=$(mktemp)
    
    case "$TASK_NAME" in
        like) title="Interested PRs" ;;
        *) title="PRs to Pull" ;;
    esac
    
    # Write header
    echo "# $title" > "$tmp_md"
    echo "" >> "$tmp_md"
    echo "| PR | Description | Status |" >> "$tmp_md"
    echo "|----|-------------|--------|" >> "$tmp_md"
    echo "" >> "$tmp_md"
    
    # Write data from JSON
    jq -r '.[] | "| #\(.id) | \(.description) | \(.status) |"' "$JSON_FILE" >> "$tmp_md"
    
    mv "$tmp_md" "$MD_FILE"
}

# List PRs (from JSON)
cmd_list() {
    init_files
    
    echo ""
    
    # Read JSON and display
    if [[ -s "$JSON_FILE" ]] && [[ $(cat "$JSON_FILE" | tr -d ' ') != "[]" ]]; then
        cat "$JSON_FILE" | jq -r '.[] | "  #\(.id) | \(.description) | \(.status)"' 2>/dev/null
    else
        echo "No PRs to pull. Use +<num> to add."
    fi
    echo ""
    
    # Interactive prompt
    echo -n "Action (+num add, -num remove, ? sync, Enter to quit): "
    read -r action
    
    if [[ -z "$action" ]]; then
        return
    fi
    
    # Process action
    case "$action" in
        +*) cmd_add "${action#+}" ;;
        -*) cmd_remove "${action#-}" ;;
        \?) cmd_sync ;;
        *) echo "Cancelled" ;;
    esac
}

# Sync PR status from GitHub
cmd_sync() {
    init_files
    
    # Check if jq can parse JSON
    if ! jq -e '.' "$JSON_FILE" >/dev/null 2>&1; then
        echo "Invalid JSON, cannot sync"
        return
    fi
    
    local count=0
    
    # Get upstream repo
    upstream_url=$(git remote get-url upstream 2>/dev/null || true)
    repo_ref=$(echo "$upstream_url" | sed -E 's|.*github\.com/||' | sed 's|\.git$||')
    
    # Get all PRs and update
    local pr_ids
    pr_ids=$(jq -r '.[] | .id' "$JSON_FILE")
    
    for pr_id in $pr_ids; do
        local description
        description=$(jq -r --arg id "$pr_id" '.[] | select(.id == $id) | .description' "$JSON_FILE")
        
        local status
        status=$(gh pr view "$pr_id" -R "$repo_ref" --json state -q '.state' 2>/dev/null) || status="unknown"
        case "$status" in
            MERGED) status="merged" ;;
            CLOSED) status="closed" ;;
            OPEN) status="open" ;;
        esac
        echo "PR #$pr_id ($description): $status"
        
        # Update JSON
        local tmp_update
        tmp_update=$(mktemp)
        jq --arg id "$pr_id" --arg status "$status" 'map(if .id == $id then .status = $status else . end)' "$JSON_FILE" > "$tmp_update" && mv "$tmp_update" "$JSON_FILE"
        
        count=$((count + 1))
    done
    
    # Sync MD from JSON
    json2md
    
    echo "Synced $count PRs from GitHub"
}

# Add PR
cmd_add() {
    local pr_num="$1"
    [[ -z "$pr_num" ]] && { echo "Usage: +<num>"; exit 1; }
    
    init_files
    
    # Check if already exists in JSON
    if jq -e --arg id "$pr_num" '.[] | select(.id == $id)' "$JSON_FILE" >/dev/null 2>&1; then
        echo "PR #$pr_num already in pull list"
        return
    fi
    
    # Fetch title from GitHub
    local title
    upstream_url=$(git remote get-url upstream 2>/dev/null || true)
    repo_ref=$(echo "$upstream_url" | sed -E 's|.*github\.com/||' | sed 's|\.git$||')
    
    title=$(gh pr view "$pr_num" -R "$repo_ref" --json title -q '.title' 2>/dev/null) || title="Unknown"
    
    # Add to JSON
    local tmp_json
    tmp_json=$(mktemp)
    jq --arg id "$pr_num" --arg desc "$title" --arg status "open" '. += [{"id": $id, "description": $desc, "status": $status}]' "$JSON_FILE" > "$tmp_json" && mv "$tmp_json" "$JSON_FILE"
    
    # Sync MD from JSON
    json2md
    
    echo "Added #$pr_num to pull: $title"
}

# Remove PR
cmd_remove() {
    local pr_num="$1"
    [[ -z "$pr_num" ]] && { echo "Usage: -<num>"; exit 1; }
    
    init_files
    
    if jq -e --arg id "$pr_num" '.[] | select(.id == $id)' "$JSON_FILE" >/dev/null 2>&1; then
        local tmp_json
        tmp_json=$(mktemp)
        jq --arg id "$pr_num" 'map(select(.id != $id))' "$JSON_FILE" > "$tmp_json" && mv "$tmp_json" "$JSON_FILE"
        
        # Sync MD from JSON
        json2md
        
        echo "Removed #$pr_num from pull"
    else
        echo "PR #$pr_num not in pull list"
    fi
}

# Main
arg="${1:-}"
case "$arg" in
    +*) cmd_add "${arg#+}" ;;
    -*) cmd_remove "${arg#-}" ;;
    \?) cmd_sync ;;
    *) cmd_list ;;
esac
